import json
import os
import re

log_path = r"C:\Users\Reda Tech\.gemini\antigravity-ide\brain\d228d0a1-fce4-4389-92e2-35acf6cf810e\.system_generated\logs\transcript.jsonl"
target_path = r"c:\Users\Reda Tech\Desktop\shiftpoint dashboard\src\app\dashboard\cpl-calculator\cpl-calculator-client.tsx"

# We want to extract the file lines as they were read in step 1 of this conversation.
# The tool calls view_file outputted the entire file:
# lines 1-800, lines 801-900, lines 900-1150, lines 1151-1301.

# Let's read the transcript line by line.
lines_dict = {}

with open(log_path, 'r', encoding='utf-8') as f:
    for line in f:
        try:
            data = json.loads(line)
            # Check if this step indices a VIEW_FILE tool or output
            if data.get('type') == 'VIEW_FILE' or 'view_file' in str(data):
                content = data.get('content', '')
                # If there are line numbers like: "1: 'use client'\n2: \n..."
                # we can parse them.
                for match in re.finditer(r"^(\d+):\s(.*)$", content, re.MULTILINE):
                    line_num = int(match.group(1))
                    line_content = match.group(2)
                    lines_dict[line_num] = line_content
        except Exception as e:
            continue

# Sort and check if we have all lines from 1 to 1301
sorted_nums = sorted(lines_dict.keys())
print(f"Extracted {len(sorted_nums)} lines. Min line: {min(sorted_nums) if sorted_nums else None}, Max line: {max(sorted_nums) if sorted_nums else None}")

# If we have the lines, let's write them to a temp backup file first
if len(sorted_nums) > 1200:
    out_lines = []
    for i in range(1, max(sorted_nums) + 1):
        # Fallback to empty if a line is missing, but they should all be there
        out_lines.append(lines_dict.get(i, ""))
    
    backup_path = target_path + ".backup"
    with open(backup_path, 'w', encoding='utf-8') as out_f:
        out_f.write("\n".join(out_lines))
    print(f"Backup written to {backup_path}")
    
    # Overwrite the target path
    with open(target_path, 'w', encoding='utf-8') as out_f:
        out_f.write("\n".join(out_lines))
    print("Target file restored successfully!")
else:
    print("Error: Could not extract enough lines from logs.")

  } else {
    console.log("Error: Could not extract enough lines from logs.");
  }
} catch (err) {
  console.error("Execution error:", err);
}

