                                            <span className="text-brand-dim">الكاش المتبقي (بعد التحويلات):</span>
                                            <span className="font-mono text-white">
                                              {Number(report.total_cash - report.personal_expenses - report.recipient_money).toLocaleString('en-US', { minimumFractionDigits: 2 })} ج.م
                                            </span>
                                          </div>
                                          <div className="flex justify-between text-xs">
                                            <span className="text-brand-dim">إجمالي رصيد المحافظ النشطة:</span>
                                            <


















































































                                            <span>تكلفة العميل (CPL Sys 1):</span>
                                            <span className="font-mono">
                                              {sys1CplVal === 'Add count First' ? (
                                                <span className="text-[10px] text-brand-accent/50 italic">أدخل العدد أولاً</span>
                                              ) : (
                                                <span>{Number(sys1CplVal).toLocaleString('en-US')} ج.م</span>
                                              )}
                                            </span>
                                          </div>
                                          <div className="flex justify-between text-xs text-brand-dim pl-2">
                                            <span>تكلفة العميل (CPL Sys 2):</span>
                                            <span className="font-mono">
                                              {sys2CplVal === 'Add count First' ? (
                                                <span className="text-[10px] text-brand-dim/40 italic">أدخل العدد أولاً</span>
                                              ) : (
                                                <span>{Number(sys2CplVal).toLocaleString('en-US')} ج.م</span>
                                              )}
           
                <p className="text-xs text-brand-dim mt-0.5">يرجى التأكد من مطابقة أرصدة المحافظ والـ SIM</p>
              </div>
            </div>

            {/* Content text */}
            <p className="text-sm font-medium text-white/90 leading-relaxed mb-6">
              أنتا متأكد أنك عدلت الكاش اللي في المحافظ وكله تمام؟
            </p>

            {/* Decision buttons */}
            <div className="flex flex-row-reverse gap-3">
              <button
                type="button"
                onClick={executeSave}
                className="flex-1 py-3 px-4 rounded-xl text-xs font-bold text-white bg-gradient-to-r from-brand-accent to-brand-accent-dark hover:from-brand-accent-dark hover:to-brand-accent transition-all duration-300 cursor-pointer text-center shadow-[0_4px_15px_rgba(139,92,246,0.3)]"
              >
                تأكيد الحفظ
              </button>
              <button
                type="button"
                onClick={() => setShowConfirmModal(false)}
                className="flex-1 py-3 px-4 rounded-xl text-xs font-bold text-brand-dim bg-white/[0.02] border border-white/[0.08] hover:bg-white/[0.05] hover:text-white transition-all duration-300 cursor-pointer text-center"
              >
                إلغاء
              </button>
            </div>

          </div>
        </div>
      )}
    </div>
  )
}















                      {activeWallets.length === 0 ? (
                        <div className="text-center py-8 text-brand-dim/50 border border-dashed border-white/[0.05] rounded-2xl">
                          لا توجد محافظ نشطة مسجلة لك حالياً في لوحة التحكم.
                        </div>
                      ) : (
                        <div className="space-y-4 max-h-[550px] overflow-y-auto pr-1">
                          {activeWallets.map((wallet) => (
                            <div key={wallet.id} className="flex items-center justify-between gap-4 py-1.5 px-3.5 rounded-xl bg-white/[0.01] border border-white/[0.03] hover:border-white/[0.06] transition-all duration-300">
                              <div className="flex items-center gap-2 text-right">
                                <Smartphone className="h-4 w-4 text-brand-accent" />
                                <span className="text-sm font-bold text-white font-mono">{wallet.phone_number}</span>
                              </div>
                              <input
                                type="number"
                                step="0.01"
                                placeholder="0.00"
                                value={walletAmounts[wallet.phone_number] || ''}
                                onChange={(e) => handleWalletAmountChange(wallet.phone_number, e.target.value)}
            <div className="flex items-center gap-3.5 mb-5 pb-4 border-b border-white/[0.04]">
              <div className="p-3 rounded-2xl bg-brand-accent/10 border border-brand-accent/20 text-brand-accent">

              </div>
              <div>
                <h3 className="text-base font-extrabold text-white">تأكيد حفظ البيانات اليومية</h3>
                <p className="text-xs text-brand-dim mt-0.5">يرجى التأكد من مطابقة أرصدة المحافظ والـ SIM</p>
              </div>
            </div>

            {/* Content text */}
            <p className="text-sm font-medium text-white/90 leading-relaxed mb-6">
              أنتا متأكد أنك عدلت الكاش اللي في المحافظ وكله تمام؟
            </p>

            {/* Decision buttons */}
            <div className="flex flex-row-reverse gap-3">
              <button
                type="button"
                onClick={executeSave}
                className="flex-1 py-3 px-4 rounded-xl text-xs font-bold text-white bg-gradient-to-r from-brand-accent to-brand-accent-dark hover:from-brand-accent-dark hover:to-brand-accent transition-all duration-300 cursor-pointer text-center shadow-[0_4px_15px_rgba(139,92,246,0.3)]"
              >
                تأكيد الحفظ
              </button>
              <button
                type="button"
                onClick={() => setShowConfirmModal(false)}
                className="flex-1 py-3 px-4 rounded-xl text-xs font-bold text-brand-dim bg-white/[0.02] border border-white/[0.08] hover:bg-white/[0.05] hover:text-white transition-all duration-300 cursor-pointer text-center"
              >
                إلغاء
              </button>
            </div>

          </div>
        </div>
      )}
    </div>
  )
}


              </div>
              ) : null}
            </form>
          )}

          {/* Tab 3: Get Data / History */}
          {activeTab === 'history' && (
            <div className="rounded-[24px] bg-brand-card border border-brand-border p-6 md:p-8 shadow-[0_8px_32px_rgba(0,0,0,0.4)] relative">
              <div className="absolute -top-[100px] -right-[100px] w-[200px] h-[200px] bg-brand-accent/5 rounded-full blur-[50px] pointer-events-none" />

              {/* Header & Date Filter */}
              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6 pb-4 border-b border-white/[0.04]">
                <div>
                  <h3 className="text-lg font-bold text-white mb-2 text-right">سجل التقارير اليومية لـ CPL والكاش</h3>
                  <p className="text-xs text-brand-dim text-right leading-relaxed">
                    يعرض الجدول جميع التقارير السابقة مرتبة بالتاريخ الأحدث أولاً. اضغط على أي صف لعرض تفاصيل المحافظ وباقي المعادلات المجمعة.
                  </p>
                </div>
                
                <div className="flex items-center justify-start md:justify-end gap-2 shrink-0 self-start md:self-center">
                  {filterDate && (
                    <button
                      type="button"
                      onClick={() => setFilterDate('')}
                      className="px-3 py-1.5 rounded-xl bg-white/5 hover:bg-white/10 text-xs text-white/80 hover:text-white transition-all cursor-pointer border border-white/[0.05]"
                    >



















              ) : (
                <>
                  {filteredReports.length === 0 ? (
                    <div className="text-center py-12 text-brand-dim/60 space-y-3">
                      <p>لا توجد تقارير مطابقة للتاريخ المحدد ({filterDate}).</p>
                      <button
                        type="button"
                        onClick={() => setFilterDate('')}
                        className="px-4 py-2 rounded-xl bg-brand-accent/20 hover:bg-brand-accent/30 text-xs text-brand-accent font-bold transition-all cursor-pointer border border-brand-accent/30"
                      >
                        عرض جميع التقارير
                      </button>
                    </div>
                  ) : (
                    <div className="overflow-x-auto">
                      <table className="w-full text-right border-collapse text-xs md:text-sm">
                        <thead>
                          <tr className="border-b border-brand-border text-brand-dim font-bold pb-4">
                            <th className="pb-4 pt-2 font-bold pr-4">التاريخ</th>
                            <th className="pb-4 pt-2 font-bold text-left font-sans">إجمالي الكاش المستلم</th>
                            <th className="pb-4 pt-2 font-bold text-left font-sans">إجمالي رصيد المحافظ النشطة</th>
                            <th className="pb-4 pt-2 font-bold text-left font-sans text-brand-accent">Marketing Sys 1</th>
                            <th className="pb-4 pt-2 font-bold text-left font-sans">الكاش النهائي المتبقي</th>
                            <th className="pb-4 pt-2 font-bold text-left font-sans">إجمالي عدد اللييدز</th>
                            <th className="pb-4 pt-2 font-bold text-center">التعديل</th>
                            <th className="pb-4 pt-2 font-bold text-center pl-4">التفاصيل</th>
                          </tr>
                        </thead>
                        <tbody className="divide-y divide-brand-border/40 text-xs md:text-sm text-white font-mono">
                          {filteredReports.map((report) => {
                            const isExpanded = expandedRowId === report.id
                            const displayDate = new Date(report.report_date).toLocaleDateString('ar-EG-u-nu-latn', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric',
                              weekday: 'long'
                            })

                            const reportWalletsDetails = report.wallets_details as any
                            let walletsList: any[] = []
                            let sys1CountVal = report.sys1_count ?? 0
                            let sys2CountVal = report.sys2_count ?? 0
                            let sys3CountVal = report.sys3_count ?? 0

                            if (reportWalletsDetails) {
                              if (Array.isArray(reportWalletsDetails)) {
                                walletsList = reportWalletsDetails
                              } else {
                                if (Array.isArray(reportWalletsDetails.wallets)) {
                                  walletsList = reportWalletsDetails.wallets
                                }
                                if (!sys1CountVal) {
                                  sys1CountVal = reportWalletsDetails.sys1_count ?? reportWalletsDetails.avera_count ?? 0
                                }
                                if (!sys2CountVal) {
                                  sys2CountVal = reportWalletsDetails.sys2_count ?? reportWalletsDetails.sotara_count ?? 0
                                }
                                if (!sys3CountVal) {
                                  sys3CountVal = reportWalletsDetails.sys3_count ?? reportWalletsDetails.best_flex_count ?? 0
                                }
                              }
                            }
                                            ) : (
                                              walletsList.map((w, idx) => (
                                                <div key={idx} className="flex justify-between text-xs items-center bg-white/[0.01] border border-white/[0.02] p-2 rounded-lg">
                                                  <span className="text-brand-dim font-mono">{w.phone}</span>
                                                  <span className="font-mono text-white font-bold">{Number(w.amount).toLocaleString('en-US')} ج.م</span>
                                                </div>
                                              ))
                                            )}
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  </td>
                                </tr>
                              )}
                            </React.Fragment>
                        )
                      })}
                    </tbody>
                  </table>
                </div>
              )}
            </>
          )}
        </div>
      )}

      {/* Confirmation Modal */}
      {showConfirmModal && (